{
    "include": ["src"],
    "compilerOptions": {
      "outDir": "dist",
      "target": "es2020",
      "declaration": true,
      "strict": true,
      "allowImportingTsExtensions": true,
      "rewriteRelativeImportExtensions": true,
      "module": "ESNext", // or "NodeNext"
      "moduleResolution": "Bundler" // or "NodeNext",
    },
    "noUncheckedIndexedAccess": true
  }