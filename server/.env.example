REDIS_URL="redis://default:password@localhost:6379/0"
JWT_SECRET="your-jwt-secret-key"
CLIENT_DOMAIN="localhost"
CLIENT_RPID="http://localhost:3000"
AXIOM_TOKEN=your-axiom-token
AXIOM_DATASET=grinda-translation
