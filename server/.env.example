# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# LOGGING
AXIOM_TOKEN=your_axiom_token
AXIOM_DATASET=grinda-translation
AXIOM_URL=https://api.axiom.co/v1/traces

# DATABASE
DATABASE_URL="postgres://username:password@hostname:port/database?connect_timeout=0&pool_timeout=0"
REDIS_URL="redis://default:password@hostname:port/0"
CACHE_TTL=360000

# AUTH & TOKEN
JWT_SECRET="your_jwt_secret_key"
CLIENT_BASE_URL="http://localhost:3000"
AUTH_TOKEN_EXPIRY_DURATION_MINUTES=60
ISSUER=localhost
SERVER_BASE_URL="http://localhost:8000"
SERVER_NAME="Hana Translate API"

# AI
OPENAI_API_KEY=your_openai_api_key

# EMAIL SERVICES
RESEND_API_KEY=your_resend_api_key