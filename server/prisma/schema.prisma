generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  createdAt DateTime
  updatedAt DateTime

  name          String
  email         String
  emailVerified Boolean
  image         String?
  isAnonymous   Boolean?

  // relations
  sessions    Session[]
  accounts    Account[]
  passkeys    Passkey[]
  apikeys     Apikey[]
  members     Member[]
  invitations Invitation[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  createdAt DateTime
  updatedAt DateTime

  expiresAt            DateTime
  token                String
  ipAddress            String?
  userAgent            String?
  activeOrganizationId String?

  // relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@unique([token])
  @@map("session")
}

model Account {
  id        String   @id
  createdAt DateTime
  updatedAt DateTime

  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  // relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@map("account")
}

model Verification {
  id        String    @id
  createdAt DateTime?
  updatedAt DateTime?

  identifier String
  value      String
  expiresAt  DateTime

  @@map("verification")
}

model Passkey {
  id        String    @id
  createdAt DateTime?

  name         String?
  publicKey    String
  credentialID String
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?

  // relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@map("passkey")
}

model Apikey {
  id        String   @id
  createdAt DateTime
  updatedAt DateTime

  name                String?
  start               String?
  prefix              String?
  key                 String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean?
  rateLimitEnabled    Boolean?
  rateLimitTimeWindow Int?
  rateLimitMax        Int?
  requestCount        Int?
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  permissions         String?
  metadata            String?

  // relations
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("apikey")
}

model Organization {
  id        String   @id
  createdAt DateTime

  name     String
  slug     String?
  logo     String?
  metadata String?

  // relations
  members      Member[]
  invitations  Invitation[]
  translations Translation[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id        String   @id
  createdAt DateTime

  role String

  // relations
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  @@map("member")
}

model Invitation {
  id String @id

  email     String
  role      String?
  status    String
  expiresAt DateTime
  inviterId String

  // relations
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String

  @@map("invitation")
}

model Language {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ISOCode String @unique
  name    String

  // relations
  sourceTranslation Translation[] @relation("SourceLanguage")
  targetTranslation Translation[] @relation("TargetLanguage")
}

model Translation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceText     String
  translatedText String
  hitCount       BigInt @default(0)

  // relations
  sourceLanguage          Language     @relation("SourceLanguage", fields: [sourceLanguageCode], references: [ISOCode], onDelete: NoAction)
  sourceLanguageCode      String
  targetLanguage          Language     @relation("TargetLanguage", fields: [targetLanguageCode], references: [ISOCode], onDelete: NoAction)
  targetLanguageCode      String
  belongsToOrganization   Organization @relation(fields: [belongsToOrganizationId], references: [id], onDelete: Cascade)
  belongsToOrganizationId String
}
